{
  "expo": {
    "name": "LUCT Reporting",
    "slug": "luct-reporting-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "platforms": [
      "android",
      "ios",
      "web"
    ],

    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "android": {
      "package": "com.lehloara.luctreportingapp",

      "permissions": [
        "INTERNET"
      ],

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true
    },

    "ios": {
      "supportsTablet": true
    },

    "web": {
      "favicon": "./assets/images/logo.png"
    },

    "plugins": [
      "expo-font"
    ],

    "extra": {
      "eas": {
        "projectId": "fef4e471-fc9b-4f45-b238-cbad9d1f0c9e"
      }
    },

    "owner": "lehloara"
  }
}